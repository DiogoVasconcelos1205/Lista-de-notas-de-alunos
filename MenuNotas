		  menu.pop_back(); // ele remove o ultimo valor da lista
          cout << "Ultima nota " << nota << " removida" <<endl;
           } 	
         break;
         
         case 3:
		 if (menu.size() > 0) { //retornando a quantidade de notas guardadas
        	cout << "Você escolheu ver primeira nota."<<endl;
		   	cout << "Primeira nota " << menu.front() << endl; // .front serve para acessar o primeiro valor da lista. 
